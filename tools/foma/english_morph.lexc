! HCP English Morphological Analyzer
! Lexc grammar for identifying regular inflected forms.
! Roots sourced from hcp_english; rules match inflection_rules table.
!
! Analysis tags map to HCP morpheme bits:
!   +Pl     = PLURAL (bit 0)
!   +Poss   = POSS (bit 1)
!   +Past   = PAST (bit 3)
!   +Prog   = PROGRESSIVE (bit 4)
!   +3Sg    = 3RD_SING (bit 5)
!   +Comp   = COMPARATIVE
!   +Sup    = SUPERLATIVE
!   +AdvLy  = ADVERB_LY

Multichar_Symbols +N +V +Adj +Adv +Pl +Past +Prog +3Sg +Comp +Sup +AdvLy +Poss

LEXICON Root
Noun ;
Verb ;
Adj  ;

! ---- NOUNS ----
LEXICON Noun
stick   Ninf ;
walk    Ninf ;
run     Ninf ;
talk    Ninf ;
watch   Ninf ;
fox     Ninf ;
cat     Ninf ;
dog     Ninf ;
book    Ninf ;
hand    Ninf ;
word    Ninf ;
play    Ninf ;
work    Ninf ;
call    Ninf ;
move    Ninf ;
place   Ninf ;
face    Ninf ;
change  Ninf ;
dance   Ninf ;
chance  Ninf ;
price   Ninf ;
piece   Ninf ;
voice   Ninf ;
force   Ninf ;
house   Ninf ;
horse   Ninf ;
sense   Ninf ;
cause   Ninf ;
nurse   Ninf ;
kiss    Ninf ;
class   Ninf ;
glass   Ninf ;
grass   Ninf ;
pass    Ninf ;
mass    Ninf ;
dress   Ninf ;
press   Ninf ;
stress  Ninf ;
guess   Ninf ;
process Ninf ;
box     Ninf ;
mix     Ninf ;
fix     Ninf ;
tax     Ninf ;
wax     Ninf ;
city    Ninf ;
party   Ninf ;
story   Ninf ;
lady    Ninf ;
body    Ninf ;
copy    Ninf ;
baby    Ninf ;
army    Ninf ;
study   Ninf ;
family  Ninf ;
country Ninf ;
century Ninf ;
activity Ninf ;
ability  Ninf ;

LEXICON Ninf
+N+Pl:^s   # ;

! ---- VERBS ----
LEXICON Verb
stick   Vinf ;
walk    Vinf ;
run     Vinf ;
talk    Vinf ;
