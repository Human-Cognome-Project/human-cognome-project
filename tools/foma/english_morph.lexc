LEXICON Vinf
+V:0        # ;
+V+3Sg:^s   # ;
+V+Past:^ed # ;
+V+Prog:^ing # ;

! ---- ADJECTIVES ----
LEXICON Adj
big     AdjInf ;
sad     AdjInf ;
mad     AdjInf ;
bad     AdjInf ;
glad    AdjInf ;
thin    AdjInf ;
slim    AdjInf ;
dim     AdjInf ;
hot     AdjInf ;
