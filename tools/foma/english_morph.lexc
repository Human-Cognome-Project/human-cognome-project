close   Vinf ;
love    Vinf ;
lose    Vinf ;
raise   Vinf ;
choose  Vinf ;
prove   Vinf ;
serve   Vinf ;
leave   Vinf ;
believe Vinf ;
achieve Vinf ;
receive Vinf ;
agree   Vinf ;
see     Vinf ;
feel    Vinf ;
deal    Vinf ;
heal    Vinf ;
reveal  Vinf ;
appeal  Vinf ;
kill    Vinf ;
fill    Vinf ;
pull    Vinf ;
roll    Vinf ;
tell    Vinf ;
sell    Vinf ;
fall    Vinf ;
call    Vinf ;
follow  Vinf ;
allow   Vinf ;
show    Vinf ;
know    Vinf ;
grow    Vinf ;
draw    Vinf ;
fix     Vinf ;
mix     Vinf ;
pass    Vinf ;
kiss    Vinf ;
miss    Vinf ;
press   Vinf ;
dress   Vinf ;
guess   Vinf ;
stress  Vinf ;
access  Vinf ;
process Vinf ;
address Vinf ;
express Vinf ;
discuss Vinf ;
push    Vinf ;
rush    Vinf ;
