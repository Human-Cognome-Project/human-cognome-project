hit     Vinf ;
bit     Vinf ;
fit     Vinf ;
pit     Vinf ;
knit    Vinf ;
split   Vinf ;
spit    Vinf ;
chat    Vinf ;
flat    Vinf ;
grab    Vinf ;
rub     Vinf ;
tub     Vinf ;
club    Vinf ;
snub    Vinf ;
drug    Vinf ;
plug    Vinf ;
shrug   Vinf ;
debug   Vinf ;
dig     Vinf ;
